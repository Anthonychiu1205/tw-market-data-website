DEMO_USER_EMAIL=
DEMO_USER_PASSWORD=
AUTH_SECRET=
API_KEY_HASH_SECRET=
API_KEY_ENCRYPTION_SECRET=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_ANALYTICS_ENABLED=true
NEXT_PUBLIC_ANALYTICS_DEBUG=false
PUBLIC_API_FREE_TIER_ENABLED=true
PUBLIC_API_CREDITS_DEDUCTION_ENABLED=false
PUBLIC_API_CREDITS_DEDUCTION_PRODUCTION_CONFIRM=false
PUBLIC_API_UPSTREAM_TIMEOUT_MS=8000
PUBLIC_API_CACHE_TTL_MS=30000
PUBLIC_API_CACHE_MAX_STALE_MS=300000
PUBLIC_API_CACHE_MAX_ENTRIES=800
BACKEND_SUMMARY_CACHE_TTL_MS=10000
NEXT_PUBLIC_SITE_URL=https://twmarketdata.com
NEXTAUTH_URL=https://twmarketdata.com
AUTH_URL=https://twmarketdata.com
AUTH_TRUST_HOST=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
DATABASE_URL=
# Neon POOLED (pgbouncer) URL — used by the app at runtime.
# DIRECT_DATABASE_URL: Neon DIRECT (non "-pooler") URL — used ONLY by `prisma migrate` (schema
# directUrl). Migrations take a pg_advisory_lock, which cannot be held across a transaction-mode
# pooler, so migrating over the pooled URL fails with P1002. Required in Vercel Production.
DIRECT_DATABASE_URL=
DB_HEALTH_CHECK_SECRET=
# Polar (payments). Secrets are set in the deployment environment, never committed.
# POLAR_ACCESS_TOKEN: website-scoped organization access token (checkouts:write,
#   customers:read; events:write reserved for Phase 2 metering).
# POLAR_API_BASE: leave unset for production (https://api.polar.sh); set the sandbox
#   base only for testing.
# NEXT_PUBLIC_SITE_URL (above) doubles as the Polar embed_origin.
POLAR_ACCESS_TOKEN=
POLAR_API_BASE=
POLAR_PRODUCT_ID_STARTER=
POLAR_PRODUCT_ID_PRO=
POLAR_PRODUCT_ID_MAX=
POLAR_PRODUCT_ID_DEVELOPER=
RESEND_API_KEY=
EMAIL_FROM="TW Market Data <onboarding@resend.dev>"

BACKEND_API_BASE_URL=
BACKEND_API_TOKEN=
# INTERNAL_METER_TOKEN: shared secret for the server-to-server credit meter endpoint
# (POST /api/internal/credits/meter), called ONLY by the read API on each paid sk_live_ call.
# Strong random value; must match the read API's copy. If unset, the endpoint fails closed (503).
INTERNAL_METER_TOKEN=
# Owner-only admin: token for POST {BACKEND_API_BASE_URL}/v2/admin/grant-plan.
# Server-side only (sent as x-admin-grant-token header); never exposed to the client.
BACKEND_ADMIN_GRANT_TOKEN=
BACKEND_API_KEY=
BACKEND_BEARER_TOKEN=
STAGING_BACKEND_API_TOKEN=
CRON_SECRET=
MARKET_MARQUEE_REFRESH_SECRET=
MARKET_MARQUEE_SNAPSHOT_PATH=

GATEWAY_SMOKE_BASE_URL=http://localhost:3000
GATEWAY_SMOKE_API_KEY=
CONFIRM_DEDUCTION_SMOKE=false
CONFIRM_SEED_TEST_WALLET=false
ALLOW_PRODUCTION_TEST_SCRIPTS=false
SEED_WALLET_USER_EMAIL=
SEED_WALLET_CREDITS=
USAGE_CHECK_USER_EMAIL=
USAGE_CHECK_API_KEY_PREFIX=

# Self-serve key API base (P0 key unification). Defaults to https://api.twmarketdata.com.
SELF_SERVE_API_BASE_URL=
